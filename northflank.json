{
  "apiVersion": "v1",
  "project": {
    "id": "fashionistar-production",
    "name": "FASHIONISTAR Production"
  },
  "services": [
    {
      "kind": "DeploymentService",
      "spec": {
        "name": "fashionistar-celery-worker",
        "billing": {
          "deploymentPlan": "nf-compute-20"
        },
        "deployment": {
          "instances": 1,
          "docker": {
            "configType": "customCommand",
            "customCommand": "celery -A backend worker --loglevel=info --concurrency=4 -Q default,ai_tasks,measurements,analytics,notifications,webhooks --max-tasks-per-child=100 --without-gossip --without-mingle --events"
          },
          "external": {
            "imagePath": "ghcr.io/fashionistar-clothings/fashionistar_backend/celery-worker:latest"
          }
        },
        "runtimeEnvironment": [
          { "name": "DJANGO_SETTINGS_MODULE", "value": "backend.config.production" },
          { "name": "CELERY_CONCURRENCY", "value": "4" },
          { "name": "CELERY_QUEUES", "value": "default,ai_tasks,measurements,analytics,notifications,webhooks" },
          { "name": "CELERY_MAX_TASKS_PER_CHILD", "value": "100" }
        ],
        "runtimeSecrets": [
          { "name": "SECRET_KEY" },
          { "name": "DATABASE_URL" },
          { "name": "REDIS_URL" },
          { "name": "CELERY_BROKER_URL" },
          { "name": "CELERY_RESULT_BACKEND" },
          { "name": "CLOUDINARY_URL" },
          { "name": "CLOUDINARY_API_KEY" },
          { "name": "CLOUDINARY_API_SECRET" },
          { "name": "CLOUDINARY_CLOUD_NAME" },
          { "name": "PAYSTACK_SECRET_KEY" },
          { "name": "TWILIO_ACCOUNT_SID" },
          { "name": "TWILIO_AUTH_TOKEN" },
          { "name": "SENTRY_DSN" }
        ]
      }
    }
  ],
  "addons": [
    {
      "kind": "Addon",
      "spec": {
        "name": "fashionistar-celery-redis",
        "type": "redis",
        "typeVersion": "8.6.1",
        "billing": {
          "replicas": 1,
          "storageClass": "ssd",
          "storage": 4096
        }
      }
    }
  ],
  "cronJobs": [
    {
      "kind": "CronJob",
      "spec": {
        "name": "fashionistar-celery-beat",
        "billing": {
          "deploymentPlan": "nf-compute-10"
        },
        "execution": {
          "schedule": "* * * * *",
          "command": "celery -A backend beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler --max-interval=10",
          "concurrencyPolicy": "Forbid"
        },
        "deployment": {
          "external": {
            "imagePath": "ghcr.io/fashionistar-clothings/fashionistar_backend/celery-worker:latest"
          }
        },
        "runtimeSecrets": [
          { "name": "SECRET_KEY" },
          { "name": "DATABASE_URL" },
          { "name": "REDIS_URL" },
          { "name": "CELERY_BROKER_URL" }
        ]
      }
    },
    {
      "kind": "CronJob",
      "spec": {
        "name": "fashionistar-health-check",
        "billing": {
          "deploymentPlan": "nf-compute-10"
        },
        "execution": {
          "schedule": "*/5 * * * *",
          "command": "curl -fsS https://api.fashionistar.net/health/ && echo 'API healthy'",
          "concurrencyPolicy": "Allow"
        },
        "deployment": {
          "docker": {
            "configType": "default"
          },
          "external": {
            "imagePath": "curlimages/curl:latest"
          }
        }
      }
    }
  ]
}
